# Copy to .env (same directory) to override defaults for docker-compose.

# Neo4j auth — change for anything you don't want to throw away.
FORMICA_NEO4J_USER=neo4j
FORMICA_NEO4J_PASSWORD=changeme

# Model source. Default assumes the prebaked AMI with weights at /opt/models/mistral-awq.
# To download from HuggingFace instead (stock DLAMI), set:
#   FORMICA_MODEL_PATH=TheBloke/Mistral-7B-Instruct-v0.2-AWQ
FORMICA_MODEL_PATH=/models/mistral-awq
FORMICA_MODEL_ID=TheBloke/Mistral-7B-Instruct-v0.2-AWQ
